  "components": {
    "schemas": {
      "AjaxResultStreamProxyVO": {
        "type": "object",
        "properties": {
          "key": {
            "type": "object",
            "properties": {}
          }
        }
      },
      "StreamProxyCreateReq": {
        "type": "object",
        "properties": {
          "app": {
            "type": "string",
            "description": "应用名称",
            "example": "live"
          },
          "stream": {
            "type": "string",
            "description": "流ID",
            "example": "test"
          },
          "url": {
            "type": "string",
            "description": "拉流地址",
            "example": "rtmp://live.hkstv.hk.lxdns.com/live/hks2"
          },
          "description": {
            "type": "string",
            "description": "代理描述"
          },
          "status": {
            "type": "integer",
            "description": "是否启用",
            "example": 1
          },
          "serverId": {
            "type": "string",
            "description": "节点ID，指定创建代理的ZLM节点",
            "example": "zlm-node-1"
          },
          "streamProxyExtendReq": {
            "$ref": "#/components/schemas/StreamProxyExtendReq",
            "description": "================================\nZLM扩展参数对象"
          }
        },
        "required": ["app", "stream", "url"]
      },
      "StreamProxyExtendReq": {
        "type": "object",
        "properties": {
          "vhost": {
            "type": "string",
            "description": "虚拟主机",
            "example": "__defaultVhost__"
          },
          "retryCount": {
            "type": "integer",
            "description": "拉流重试次数，默认-1无限重试",
            "example": -1
          },
          "rtpType": {
            "type": "integer",
            "description": "RTSP拉流方式：0=TCP，1=UDP，2=组播",
            "example": 0
          },
          "timeoutSec": {
            "type": "integer",
            "description": "拉流超时时间(秒)",
            "example": 10
          },
          "enableHls": {
            "type": "boolean",
            "description": "是否转换成HLS-MPEGTS协议",
            "example": true
          },
          "enableHlsFmp4": {
            "type": "boolean",
            "description": "是否转换成HLS-FMP4协议",
            "example": false
          },
          "enableMp4": {
            "type": "boolean",
            "description": "是否允许MP4录制",
            "example": false
          },
          "enableRtsp": {
            "type": "boolean",
            "description": "是否转RTSP协议",
            "example": true
          },
          "enableRtmp": {
            "type": "boolean",
            "description": "是否转RTMP/FLV协议",
            "example": true
          },
          "enableTs": {
            "type": "boolean",
            "description": "是否转HTTP-TS/WS-TS协议",
            "example": false
          },
          "enableFmp4": {
            "type": "boolean",
            "description": "是否转HTTP-FMP4/WS-FMP4协议",
            "example": false
          },
          "hlsDemand": {
            "type": "boolean",
            "description": "HLS是否按需生成(有人观看才生成)",
            "example": false
          },
          "rtspDemand": {
            "type": "boolean",
            "description": "RTSP是否按需生成(有人观看才生成)",
            "example": false
          },
          "rtmpDemand": {
            "type": "boolean",
            "description": "RTMP是否按需生成(有人观看才生成)",
            "example": false
          },
          "tsDemand": {
            "type": "boolean",
            "description": "TS是否按需生成(有人观看才生成)",
            "example": false
          },
          "fmp4Demand": {
            "type": "boolean",
            "description": "FMP4是否按需生成(有人观看才生成)",
            "example": false
          },
          "enableAudio": {
            "type": "boolean",
            "description": "转协议时是否开启音频",
            "example": true
          },
          "addMuteAudio": {
            "type": "boolean",
            "description": "无音频时是否添加静音AAC音频",
            "example": false
          },
          "mp4SavePath": {
            "type": "string",
            "description": "MP4录制文件保存根目录，置空使用默认"
          },
          "mp4MaxSecond": {
            "type": "integer",
            "description": "MP4录制切片大小(秒)",
            "example": 300
          },
          "mp4AsPlayer": {
            "type": "boolean",
            "description": "MP4录制是否当作观看者参与播放人数计数",
            "example": false
          },
          "hlsSavePath": {
            "type": "string",
            "description": "HLS文件保存根目录，置空使用默认"
          },
          "modifyStamp": {
            "type": "integer",
            "description": "时间戳覆盖模式：0=绝对时间戳，1=系统时间戳，2=相对时间戳",
            "example": 0
          },
          "autoClose": {
            "type": "boolean",
            "description": "无人观看是否自动关闭流(不触发无人观看hook)",
            "example": false
          }
        }
      },
      "AjaxResultLong": {
        "type": "object",
        "properties": {
          "key": {
            "type": "object",
            "properties": {}
          }
        }
      },
      "StreamProxyUpdateReq": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "代理ID",
            "format": "int64",
            "example": 1
          },
          "app": {
            "type": "string",
            "description": "应用名称",
            "example": "live"
          },
          "stream": {
            "type": "string",
            "description": "流ID",
            "example": "test"
          },
          "url": {
            "type": "string",
            "description": "拉流地址",
            "example": "rtmp://live.hkstv.hk.lxdns.com/live/hks2"
          },
          "description": {
            "type": "string",
            "description": "代理描述"
          },
          "status": {
            "type": "integer",
            "description": "代理状态 1启用 0禁用",
            "example": 1
          },
          "serverId": {
            "type": "string",
            "description": "节点ID，指定创建代理的ZLM节点",
            "example": "zlm-node-1"
          },
          "extend": {
            "type": "string",
            "description": "扩展字段"
          },
          "streamProxyExtendReq": {
            "$ref": "#/components/schemas/StreamProxyExtendReq",
            "description": "================================\nZLM扩展参数对象"
          }
        },
        "required": ["id"]
      },
      "StreamProxyQueryReq": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "代理ID",
            "format": "int64"
          },
          "app": {
            "type": "string",
            "description": "应用名称",
            "example": "live"
          },
          "stream": {
            "type": "string",
            "description": "流ID",
            "example": "test"
          },
          "proxyKey": {
            "type": "string",
            "description": "代理Key"
          },
          "url": {
            "type": "string",
            "description": "拉流地址"
          },
          "description": {
            "type": "string",
            "description": "代理描述"
          },
          "status": {
            "type": "integer",
            "description": "状态 1启用 0禁用"
          },
          "onlineStatus": {
            "type": "integer",
            "description": "在线状态 1在线 0离线"
          },
          "serverId": {
            "type": "string",
            "description": "服务器ID"
          }
        }
      },
      "AjaxResultBoolean": {
        "type": "object",
        "properties": {
          "key": {
            "type": "object",
            "properties": {}
          }
        }
      },
      "AjaxResultVoid": {
        "type": "object",
        "properties": {
          "key": {
            "type": "object",
            "properties": {}
          }
        }
      },
      "AjaxResultStreamProxyListResp": {
