  "components": {
    "schemas": {
      "AjaxResultPushProxyVO": {
        "type": "object",
        "properties": {
          "key": {
            "type": "object",
            "properties": {}
          }
        }
      },
      "PushProxyExtendReq": {
        "type": "object",
        "properties": {
          "vhost": {
            "type": "string",
            "description": "虚拟主机",
            "default": "__defaultVhost__",
            "example": "__defaultVhost__"
          },
          "retryCount": {
            "type": "integer",
            "description": "推流重试次数，-1表示无限重试",
            "default": -1,
            "example": -1
          },
          "rtpType": {
            "type": "integer",
            "description": "rtsp推流方式，0:tcp，1:udp",
            "default": 0,
            "example": 0
          },
          "timeoutSec": {
            "type": "integer",
            "description": "推流超时时间，单位秒",
            "default": 10,
            "example": 10
          },
          "autoReconnect": {
            "type": "boolean",
            "description": "是否启用自动重连",
            "default": false,
            "example": true
          },
          "retryInterval": {
            "type": "integer",
            "description": "推流失败重试间隔，单位秒",
            "default": 5,
            "example": 5
          },
          "enableMonitor": {
            "type": "boolean",
            "description": "是否启用推流状态监控",
            "default": false,
            "example": true
          },
          "qualityThreshold": {
            "type": "number",
            "description": "推流质量监控阈值",
            "default": 0.8,
            "example": 0.8
          },
          "maxBitrate": {
            "type": "integer",
            "description": "最大推流码率，单位kbps",
            "example": 5000
          },
          "minBitrate": {
            "type": "integer",
            "description": "最小推流码率，单位kbps",
            "example": 500
          },
          "enableAuth": {
            "type": "boolean",
            "description": "是否启用推流认证",
            "default": false,
            "example": false
          },
          "authUser": {
            "type": "string",
            "description": "推流认证用户名",
            "example": "user"
          },
          "authPassword": {
            "type": "string",
            "description": "推流认证密码",
            "example": "password"
          },
          "autoStop": {
            "type": "boolean",
            "description": "无人观看是否自动停止推流",
            "default": false,
            "example": false
          },
          "autoStopDelay": {
            "type": "integer",
            "description": "自动停止延迟时间，单位秒",
            "default": 300,
            "example": 300
          },
          "priority": {
            "type": "integer",
            "description": "推流优先级，数值越大优先级越高",
            "default": 1,
            "example": 1
          },
          "enableEncrypt": {
            "type": "boolean",
            "description": "是否启用推流加密",
            "default": false,
            "example": false
          },
          "encryptKey": {
            "type": "string",
            "description": "推流加密密钥",
            "example": "secret_key"
          }
        }
      },
      "AjaxResultLong": {
        "type": "object",
        "properties": {
          "key": {
            "type": "object",
            "properties": {}
          }
        }
      },
      "PushProxyCreateReq": {
        "type": "object",
        "properties": {
          "app": {
            "type": "string",
            "description": "应用名称",
            "example": "live"
          },
          "stream": {
            "type": "string",
            "description": "流名称",
            "example": "test"
          },
